{
  "name": "koishi-plugin-japanese-adaptation-vits",
  "description": "自用，使用 minimax 生成语音，添加白名单机制、保留语气词",
  "version": "1.0.0",
  "contributors": [
    "唐晓啡 <630320467@qq.com>"
  ],
  "main": "lib/index.js",
  "module": "esm/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./esm/index.js",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "esm",
    "readme.md"
  ],
  "license": "MIT",
  "keywords": [
    "chatbot",
    "koishi",
    "plugin",
    "minimax",
    "tts",
    "vits",
    "chatluna",
    "voice",
    "speech",
    "japanese"
  ],
  "peerDependencies": {
    "@koishijs/plugin-console": "^5.16.0",
    "koishi": "^4.18.10"
  },
  "dependencies": {
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@koishijs/client": "^5.16.0",
    "@types/form-data": "^2.5.0",
    "@types/node": "^20.0.0",
    "tsc-alias": "^1.8.0",
    "typescript": "^5.0.0",
    "vue": "^3.3.0"
  },
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json && tsc -p tsconfig.esm.json && tsc-alias -p tsconfig.esm.json",
    "build:dev": "tsc --watch",
    "clean": "rm -rf lib",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "inject": {
    "optional": [
      "console",
      "chatluna"
    ]
  },
  "homepage": "https://github.com/Lichen502/japanese-adaptation-vits#readme",
  "koishi": {
    "description": {
      "en": "japanese-adaptation-vits",
      "zh": "自用插件。japanese-adaptation-vits插件"
    },
    "service": {
      "implements": [
        "japanese-adaptation-vits"
      ]
    }
  }
}
